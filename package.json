{
  "name": "miranda",
  "displayName": "Miranda Language Support",
  "description": "Syntax highlighting and ESLint-style code quality linting for the Miranda functional programming language",
  "version": "0.1.0",
  "publisher": "miranda-lang",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages",
    "Linters"
  ],
  "keywords": [
    "miranda",
    "functional",
    "haskell",
    "lint"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onLanguage:miranda",
    "onCommand:miranda.runLint",
    "onCommand:miranda.startTutorial",
    "onCommand:miranda.openBasicExample",
    "onCommand:miranda.openComprehensionsExample",
    "onCommand:miranda.openFibExample",
    "onCommand:miranda.openLanguageGuide",
    "onCommand:miranda.openLintSettings",
    "onCommand:miranda.openWalkthrough"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "miranda",
        "aliases": [
          "Miranda",
          "miranda"
        ],
        "extensions": [
          ".m"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "miranda",
        "scopeName": "source.miranda",
        "path": "./syntaxes/miranda.tmLanguage.json"
      }
    ],
    "configuration": {
      "title": "Miranda",
      "properties": {
        "miranda.lint.enable": {
          "type": "boolean",
          "default": true,
          "description": "Enable Miranda linting"
        },
        "miranda.lint.run": {
          "type": "string",
          "enum": [
            "onType",
            "onSave",
            "onTypeAndSave"
          ],
          "default": "onTypeAndSave",
          "description": "When to run the Miranda linter"
        },
        "miranda.lint.maxLineLength": {
          "type": "number",
          "default": 80,
          "description": "Maximum allowed line length"
        },
        "miranda.lint.indentSize": {
          "type": "number",
          "default": 1,
          "description": "Expected indentation step (in spaces) for the offside rule"
        },
        "miranda.lint.rules.noTrailingSpaces": {
          "type": "string",
          "enum": [
            "off",
            "warn",
            "error"
          ],
          "default": "warn",
          "description": "Disallow trailing whitespace"
        },
        "miranda.lint.rules.requireFinalNewline": {
          "type": "string",
          "enum": [
            "off",
            "warn",
            "error"
          ],
          "default": "warn",
          "description": "Require newline at end of file"
        },
        "miranda.lint.rules.noTabs": {
          "type": "string",
          "enum": [
            "off",
            "warn",
            "error"
          ],
          "default": "warn",
          "description": "Disallow tab characters"
        },
        "miranda.lint.rules.consistentIndent": {
          "type": "string",
          "enum": [
            "off",
            "warn",
            "error"
          ],
          "default": "error",
          "description": "Enforce consistent indentation for where/offside blocks"
        },
        "miranda.lint.rules.noDuplicateDefinitions": {
          "type": "string",
          "enum": [
            "off",
            "warn",
            "error"
          ],
          "default": "error",
          "description": "Disallow duplicate top-level definitions"
        },
        "miranda.lint.rules.noUndefinedIdentifier": {
          "type": "string",
          "enum": [
            "off",
            "warn",
            "error"
          ],
          "default": "warn",
          "description": "Warn on identifiers not defined in scope or standard library"
        },
        "miranda.lint.rules.noUnusedDefinitions": {
          "type": "string",
          "enum": [
            "off",
            "warn",
            "error"
          ],
          "default": "warn",
          "description": "Warn on top-level definitions that are never referenced"
        },
        "miranda.lint.rules.booleanLiteralCase": {
          "type": "string",
          "enum": [
            "off",
            "warn",
            "error"
          ],
          "default": "error",
          "description": "Require True/False (capitalized) boolean literals"
        },
        "miranda.lint.rules.commentStyle": {
          "type": "string",
          "enum": [
            "off",
            "warn",
            "error"
          ],
          "default": "warn",
          "description": "Require || for comments instead of other styles"
        },
        "miranda.lint.rules.noSingleCharNames": {
          "type": "string",
          "enum": [
            "off",
            "warn",
            "error"
          ],
          "default": "off",
          "description": "Discourage single-character identifiers except common ones (x, y, n, f, g, a, b)"
        },
        "miranda.lint.rules.maxLineLength": {
          "type": "string",
          "enum": [
            "off",
            "warn",
            "error"
          ],
          "default": "warn",
          "description": "Enforce maximum line length"
        },
        "miranda.lint.rules.unmatchedQuotes": {
          "type": "string",
          "enum": [
            "off",
            "warn",
            "error"
          ],
          "default": "error",
          "description": "Detect unmatched string or character quotes"
        },
        "miranda.lint.rules.reservedWordAsIdentifier": {
          "type": "string",
          "enum": [
            "off",
            "warn",
            "error"
          ],
          "default": "error",
          "description": "Disallow using reserved words as identifiers"
        }
      }
    },
    "commands": [
      {
        "command": "miranda.startTutorial",
        "title": "Miranda: Start Tutorial",
        "icon": "$(rocket)"
      },
      {
        "command": "miranda.runLint",
        "title": "Miranda: Run Linter",
        "icon": "$(debug-start)"
      },
      {
        "command": "miranda.openWalkthrough",
        "title": "Miranda: Open Walkthrough",
        "icon": "$(book)"
      },
      {
        "command": "miranda.openBasicExample",
        "title": "Miranda: Open Basic Ideas Example"
      },
      {
        "command": "miranda.openComprehensionsExample",
        "title": "Miranda: Open List Comprehensions Example"
      },
      {
        "command": "miranda.openFibExample",
        "title": "Miranda: Open Fibonacci Example"
      },
      {
        "command": "miranda.openLanguageGuide",
        "title": "Miranda: Open Language Guide"
      },
      {
        "command": "miranda.openLintSettings",
        "title": "Miranda: Open Lint Settings"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "miranda.startTutorial",
          "when": "resourceLangId == miranda",
          "group": "navigation@1"
        },
        {
          "command": "miranda.openWalkthrough",
          "when": "resourceLangId == miranda",
          "group": "navigation@2"
        },
        {
          "command": "miranda.runLint",
          "when": "resourceLangId == miranda",
          "group": "navigation@3"
        }
      ],
      "editor/context": [
        {
          "command": "miranda.startTutorial",
          "when": "resourceLangId == miranda",
          "group": "miranda@1"
        },
        {
          "command": "miranda.openWalkthrough",
          "when": "resourceLangId == miranda",
          "group": "miranda@2"
        },
        {
          "command": "miranda.runLint",
          "when": "resourceLangId == miranda",
          "group": "miranda@3"
        }
      ],
      "commandPalette": [
        {
          "command": "miranda.startTutorial"
        },
        {
          "command": "miranda.openWalkthrough"
        },
        {
          "command": "miranda.runLint"
        },
        {
          "command": "miranda.openBasicExample"
        },
        {
          "command": "miranda.openComprehensionsExample"
        },
        {
          "command": "miranda.openFibExample"
        },
        {
          "command": "miranda.openLanguageGuide"
        },
        {
          "command": "miranda.openLintSettings"
        }
      ]
    },
    "walkthroughs": [
      {
        "id": "miranda-getting-started",
        "title": "Get Started with Miranda",
        "description": "Learn Miranda syntax, explore tutorial examples, and configure ESLint-style linting in VS Code.",
        "steps": [
          {
            "id": "open-basic-example",
            "title": "Open your first Miranda script",
            "description": "Miranda programs are **scripts** — collections of equations in `.m` files. Function application uses juxtaposition: `sq x` not `sq(x)`.\n\n[Open Basic Ideas](command:miranda.openBasicExample)",
            "media": {
              "svg": "media/walkthrough/welcome.svg",
              "altText": "Miranda script with equations and list operations"
            },
            "completionEvents": [
              "onCommand:miranda.openBasicExample"
            ]
          },
          {
            "id": "explore-syntax",
            "title": "Explore syntax highlighting",
            "description": "This extension highlights comments (`||`), directives (`%include`), keywords (`where`, `if`), operators (`::`, `<-`, `++`), list comprehensions, and type declarations.\n\n[Open List Comprehensions](command:miranda.openComprehensionsExample)",
            "media": {
              "svg": "media/walkthrough/syntax.svg",
              "altText": "Miranda quicksort with highlighted keywords and operators"
            },
            "completionEvents": [
              "onCommand:miranda.openComprehensionsExample"
            ]
          },
          {
            "id": "run-linter",
            "title": "Run the Miranda linter",
            "description": "Open any `.m` file and run the linter to check 13 ESLint-style rules — boolean literals, indentation, undefined identifiers, and more.\n\n[Run Linter](command:miranda.runLint)",
            "media": {
              "svg": "media/walkthrough/linter.svg",
              "altText": "Linter diagnostics for boolean literal case and final newline"
            },
            "completionEvents": [
              "onCommand:miranda.runLint"
            ]
          },
          {
            "id": "pattern-matching",
            "title": "Try pattern matching",
            "description": "Miranda functions can be defined by **multiple equations** with different patterns — on numbers, lists `(a:x)`, and tuples.\n\n[Open Fibonacci Example](command:miranda.openFibExample)",
            "media": {
              "svg": "media/walkthrough/patterns.svg",
              "altText": "take function defined with pattern matching on lists"
            },
            "completionEvents": [
              "onCommand:miranda.openFibExample"
            ]
          },
          {
            "id": "configure-lint",
            "title": "Configure lint rules",
            "description": "Adjust when linting runs and set per-rule severity (`off`, `warn`, `error`) under **Settings › Miranda**.\n\n[Open Lint Settings](command:miranda.openLintSettings)",
            "media": {
              "svg": "media/walkthrough/settings.svg",
              "altText": "Miranda lint settings in VS Code"
            },
            "completionEvents": [
              "onSettingChanged:miranda.lint.enable",
              "onSettingChanged:miranda.lint.run",
              "onSettingChanged:miranda.lint.rules.booleanLiteralCase"
            ]
          },
          {
            "id": "language-guide",
            "title": "Read the language guide",
            "description": "Continue with the full tutorial adapted from David Turner's overview — guarded equations, lazy lists, algebraic types, and more.\n\n[Open Language Guide](command:miranda.openLanguageGuide)\n\n[Read Turner Overview](https://www.cs.kent.ac.uk/people/staff/dat/miranda/Overview.html)",
            "media": {
              "markdown": "media/walkthrough/language-guide.md"
            },
            "completionEvents": [
              "onCommand:miranda.openLanguageGuide",
              "onLink:https://www.cs.kent.ac.uk/people/staff/dat/miranda/Overview.html"
            ]
          }
        ]
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts",
    "test": "npm run compile && tsc -p tsconfig.test.json && mocha",
    "test:grammar": "vscode-tmgrammar-test -g syntaxes/miranda.tmLanguage.json 'src/test/grammar/**/*.test.m'",
    "test:all": "npm test && npm run test:grammar",
    "dev": "bash scripts/dev.sh",
    "guide": "bash scripts/dev.sh --walkthrough --skip-tests",
    "start": "bash scripts/dev.sh"
  },
  "devDependencies": {
    "@types/chai": "^4.3.11",
    "@types/mocha": "^10.0.6",
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "chai": "^4.4.1",
    "mocha": "^10.3.0",
    "mock-require": "^3.0.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3",
    "vscode-oniguruma": "^1.7.0",
    "vscode-textmate": "^9.0.0",
    "vscode-tmgrammar-test": "^0.1.3"
  }
}
