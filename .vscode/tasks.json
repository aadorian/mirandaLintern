{
  "version": "2.0.0",
  "tasks": [
    {
      "type": "npm",
      "script": "compile",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": "$tsc"
    },
    {
      "type": "npm",
      "script": "test",
      "group": "test",
      "problemMatcher": []
    },
    {
      "type": "npm",
      "script": "test:grammar",
      "group": "test",
      "problemMatcher": []
    },
    {
      "type": "npm",
      "script": "test:all",
      "group": "test",
      "problemMatcher": []
    },
    {
      "type": "shell",
      "label": "Dev: install, test & launch",
      "command": "bash scripts/dev.sh",
      "group": "none",
      "problemMatcher": []
    }
  ]
}
